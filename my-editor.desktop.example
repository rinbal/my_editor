# Linux launcher template for MyEditor
# See README.md > App Shortcuts for setup instructions

[Desktop Entry]
Version=1.0
Type=Application
Name=MyEditor
Comment=Minimal note-taking text editor
Exec=/path/to/my_editor/.venv/bin/python /path/to/my_editor/main.py %F
Path=/path/to/my_editor
Icon=accessories-text-editor
Terminal=false
Categories=Office;TextEditor;
MimeType=text/plain;text/html;text/markdown;text/x-python;text/x-csrc;text/x-java;application/json;text/xml;text/css;text/x-yaml;text/x-script.python;
StartupNotify=true
